@inherits LayoutComponentBase

<div class="flex flex-col min-h-screen bg-slate-50">
    <!-- Top Navbar -->
    <header class="h-16 border-b border-slate-200 bg-white shadow-sm flex items-center px-6 shrink-0 z-10">
        <!-- Brand -->
        <div class="flex items-center gap-3 w-64 shrink-0">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-md shadow-brand-500/20">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            </div>
            <div>
                <h1 class="text-lg font-bold text-slate-900 tracking-tight leading-tight">FocusMed</h1>
            </div>
        </div>

        <!-- Main Navigation -->
        <nav class="flex-1 flex items-center gap-2">
            <a href="/"
               class="flex items-center gap-2 px-4 py-2 rounded-lg bg-brand-50 text-brand-700 border border-brand-100 transition-all duration-200 hover:bg-brand-100 font-medium text-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
                Études
            </a>
        </nav>

        <!-- Right Side (Server Status + User) -->
        <div class="flex items-center gap-6 shrink-0">
            <div class="flex items-center gap-2 text-xs font-semibold text-slate-600 bg-slate-100 px-3 py-1.5 rounded-full border border-slate-200">
                <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse glow-green"></div>
                Serveur actif
            </div>
            <div class="w-8 h-8 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center cursor-pointer hover:bg-slate-200 transition-colors">
                <svg class="w-4 h-4 text-slate-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto flex flex-col min-w-0">
        <div class="p-8 max-w-[1600px] w-full mx-auto">
            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui" class="hidden fixed bottom-4 left-1/2 -translate-x-1/2 bg-red-100 text-red-900 border border-red-200 px-6 py-3 rounded-xl shadow-lg text-sm z-50" data-nosnippet>
    Une erreur inattendue s'est produite.
    <a href="." class="underline hover:text-red-700 ml-2 font-medium">Recharger</a>
</div>
