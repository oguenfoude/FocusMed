{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "%FOCUSMED_DATA%/logs/focusmed-.log",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "%FOCUSMED_DATA%/logs/dicom_associations.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionString": "Host=localhost;Port=5432;Database=focusmed;Username=postgres;Password=postgres",
  "ArchivePath": "%FOCUSMED_DATA%/archive",
  "StudyStabilizationSeconds": 60,
  "TargetPrinterName": "",
  "DicomNetworking": {
    "AETitle": "FOCUSMED_SCP",
    "DicomPort": 11112,
    "MaxPduSize": 65536,
    "BindAddress": "0.0.0.0",
    "EnforceAeWhitelist": false,
    "SupportedTransferSyntaxes": [
      "ImplicitVRLittleEndian",
      "ExplicitVRLittleEndian",
      "JPEGLSLossless",
      "JPEG2000Lossless",
      "RLELossless",
      "JPEGProcess1",
      "JPEGProcess2_4",
      "JPEGProcess14",
      "MPEG2",
      "MPEG4AVCH264HighProfileLevel41"
    ],
    "AllowedCallingAETitles": [],
    "StorageCommitmentScuMapping": {},
    "FilmPrinters": [],
    "StorageForwardTargets": []
  }
}
