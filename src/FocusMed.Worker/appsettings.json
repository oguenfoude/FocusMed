{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "%FOCUSMED_DATA%/logs/focusmed-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "BindAddress": "0.0.0.0",
  "DicomPort": 11112,
  "AETitle": "FOCUSMED_SCP",
  "DatabasePath": "%FOCUSMED_DATA%/db/focusmed.db",
  "ArchivePath": "%FOCUSMED_DATA%/archive",
  "StudyStabilizationSeconds": 60
}
